.category-page {
  height: calc(100vh - 100rpx);
  position: relative;
}

.top-search {
  margin-top: 16rpx;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  color: var(--text-muted);
}

.toolbar {
  height: 84rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sort {
  height: 56rpx;
  min-width: 96rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--border-color);
  background: #fff;
  color: var(--text-secondary);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sort.active {
  border-color: var(--brand-primary);
  background: var(--brand-primary);
  color: #fff;
  font-weight: 600;
}

.filter-btn {
  margin-left: auto;
  height: 56rpx;
  min-width: 104rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: #fff;
}

.main {
  height: calc(100% - 176rpx);
  display: flex;
  gap: 16rpx;
}

.left-nav {
  width: 180rpx;
  height: 100%;
  padding: 12rpx 0;
}

.nav-item {
  height: 80rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.nav-item.active {
  color: var(--brand-primary);
  border-left: 6rpx solid var(--brand-primary);
  background: #fff7f6;
}

.right-box {
  flex: 1;
  min-width: 0;
  height: 100%;
}

.right-list {
  height: 100%;
}

.right-list product-card {
  margin-bottom: 16rpx;
}

.filter-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 20;
}

.filter-panel {
  position: fixed;
  right: 0;
  top: 0;
  bottom: 0;
  width: 540rpx;
  background: #fff;
  z-index: 21;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.group {
  margin-top: 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.chips {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: #fff;
}

.chip.active {
  border-color: var(--brand-primary);
  color: #fff;
  background: var(--brand-primary);
}

.panel-actions {
  margin-top: auto;
  display: flex;
  gap: 12rpx;
}

.ghost,
.primary {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.ghost {
  background: #f2f2f2;
  color: var(--text-secondary);
}

.primary {
  background: var(--brand-primary);
  color: #fff;
}

.sku-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 30;
}

.sku-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  z-index: 31;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom) + 120rpx);
}

.sku-loading {
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 26rpx;
}

.sku-head {
  display: flex;
  align-items: center;
}

.sku-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.sku-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.sku-price {
  color: #ff4d4f;
  font-size: 44rpx;
  font-weight: 600;
}

.sku-stock {
  margin-top: 8rpx;
  color: #9a9a9a;
  font-size: 24rpx;
}

.sku-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #999;
  font-size: 44rpx;
  line-height: 56rpx;
  text-align: center;
}

.sku-section {
  margin-top: 24rpx;
  border-top: 2rpx solid #f3f3f3;
  padding-top: 22rpx;
}

.sku-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sku-chips {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sku-chip {
  min-width: 112rpx;
  height: 60rpx;
  border-radius: 10rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background: #fff;
}

.sku-chip.active {
  border-color: #ff4d4f;
  color: #ff4d4f;
  background: #fff6f6;
}

.sku-chip.disabled {
  border-color: #ececec;
  color: #c3c3c3;
  background: #f7f7f7;
}


.sku-qty-row {
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #f3f3f3;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sku-qty-box {
  display: flex;
  align-items: center;
}

.sku-qty-btn {
  width: 72rpx;
  height: 56rpx;
  background: #f5f5f5;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.sku-qty-btn.disabled {
  background: #f0f0f0;
  color: #ccc;
}


.sku-qty-value {
  width: 86rpx;
  height: 56rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #333;
  border-top: 2rpx solid #f5f5f5;
  border-bottom: 2rpx solid #f5f5f5;
}

.sku-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.sku-add,
.sku-buy {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.sku-add {
  background: linear-gradient(90deg, #f4c55c 0%, #f0a93f 100%);
  color: #fff;
}

.sku-buy {
  background: linear-gradient(90deg, #ff8f8f 0%, #ff4d4f 100%);
  color: #fff;
}

.sku-add.disabled,
.sku-buy.disabled {
  opacity: 0.55;
}





