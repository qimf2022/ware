.list {
  padding: 20rpx;
}

.item {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.no {
  color: #333;
  font-size: 26rpx;
}

.status {
  color: #ff4d4f;
  font-size: 26rpx;
}

.info {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.type {
  color: #666;
  font-size: 26rpx;
}

.time {
  color: #999;
  font-size: 24rpx;
}
