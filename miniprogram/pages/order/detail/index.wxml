<page-shell>
  <view class="container">
    <state-view wx:if="{{pageState !== 'ready'}}" state="{{pageState}}" emptyText="订单不存在" />

    <view wx:if="{{pageState === 'ready'}}">
      <view class="card block">
        <view class="row"><text>订单号</text><text>{{order.orderNo}}</text></view>
        <view class="row"><text>状态</text><text class="status">{{order.status}}</text></view>
        <view class="row"><text>下单时间</text><text>{{order.createdAt}}</text></view>
      </view>

      <view class="card block section-gap">
        <view class="title">收货信息</view>
        <view class="desc">{{order.address.name}} {{order.address.phone}}</view>
        <view class="desc">{{order.address.province}}{{order.address.city}}{{order.address.district}}{{order.address.detail}}</view>
      </view>

      <view class="card block section-gap">
        <view class="title">商品信息</view>
        <view class="item" wx:for="{{order.items}}" wx:key="id">
          <view>{{item.title}}</view>
          <view class="muted">{{item.size}} · {{item.material}} × {{item.quantity}}</view>
          <view class="price">¥{{item.price}}</view>
        </view>
      </view>

      <view class="card block section-gap">
        <view class="row"><text>商品金额</text><text>¥{{order.amounts.productAmount}}</text></view>
        <view class="row"><text>运费</text><text>¥{{order.amounts.freightAmount}}</text></view>
        <view class="row"><text>实付</text><text class="price">¥{{order.amounts.payAmount}}</text></view>
      </view>

      <view class="ops section-gap">
        <view class="btn ui-btn ui-btn--secondary" bindtap="onViewLogistics">查看物流</view>
        <view class="btn ui-btn ui-btn--secondary" wx:if="{{afterSaleRecord}}" bindtap="onViewAfterSale">售后详情</view>
        <view class="btn ui-btn ui-btn--danger" wx:else bindtap="onApplyAfterSale">申请售后</view>
      </view>
    </view>
  </view>
</page-shell>
