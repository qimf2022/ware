.block {
  margin-top: 16rpx;
  padding: 20rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.title {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.desc,
.item {
  color: var(--text-secondary);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.status {
  color: var(--brand-primary);
}

.ops {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.btn {
  height: 64rpx;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

