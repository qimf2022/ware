.page-wrap {
  padding-bottom: 130rpx;
}

.delivery-wrap {
  margin-top: 16rpx;
  padding: 18rpx;
  background: linear-gradient(180deg, rgba(255, 77, 79, 0.9) 0%, #fff 100%);
}

.delivery-tabs {
  display: flex;
  gap: 12rpx;
}

.delivery-tab {
  flex: 1;
  height: 68rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #5c5c5c;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delivery-tab.active {
  background: #fff;
  color: #222;
  font-weight: 600;
}

.address {
  margin-top: 14rpx;
  border-radius: 14rpx;
  background: #fff;
  padding: 22rpx 18rpx;
}

.name-row {
  font-size: 28rpx;
  color: #222;
  font-weight: 600;
}

.detail {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7f7f7f;
}

.empty-address {
  color: #808080;
  font-size: 32rpx;
}

.goods-box,
.amount-box {
  padding: 20rpx;
}

.shop-row {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 14rpx;
  background: #f5f5f5;
}

.meta {
  flex: 1;
}

.title {
  font-size: 34rpx;
  color: #222;
}

.spec,
.qty {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #a2a2a2;
}

.price {
  color: #2c2c2c;
  font-size: 46rpx;
}

.row {
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #8e8e8e;
  font-size: 34rpx;
  border-bottom: 1rpx solid #f3f3f3;
}

.row.summary {
  border-bottom: 0;
  justify-content: flex-end;
  color: #8e8e8e;
}

.highlight {
  color: #ff4d4f;
}

.remark-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  padding: 14rpx 0;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  box-shadow: 0 -8rpx 16rpx rgba(0, 0, 0, 0.04);
}

.sum {
  color: #ff4d4f;
  font-size: 38rpx;
  font-weight: 600;
}

.sum-price {
  color: #ff4d4f;
}


.submit-btn,
.go-btn {
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 46rpx;
  font-size: 34rpx;
}

.empty-wrap {
  margin-top: 24rpx;
  padding: 80rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
