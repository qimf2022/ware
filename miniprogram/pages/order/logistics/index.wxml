<page-shell>
  <view class="container">
    <state-view wx:if="{{pageState !== 'ready'}}" state="{{pageState}}" emptyText="暂无物流信息" />

    <view wx:if="{{pageState === 'ready' && logistics}}">
      <view class="card head">
        <view class="row"><text>快递公司</text><text>{{logistics.company}}</text></view>
        <view class="row"><text>运单号</text><text>{{logistics.trackingNo}}</text></view>
        <view class="row"><text>签收状态</text><text class="status">{{logistics.signed ? '已签收' : '运输中'}}</text></view>
      </view>

      <view class="card section-gap trace">
        <view class="title">物流节点</view>
        <view class="node" wx:for="{{logistics.traces}}" wx:key="index">
          <view class="dot"></view>
          <view class="content">
            <view class="text">{{item.status}}</view>
            <view class="time">{{item.time}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</page-shell>
