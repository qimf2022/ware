.result-wrap {
  padding-top: 40rpx;
}

.box {
  padding: 60rpx 24rpx;
  display: flex;
  align-items: center;
  flex-direction: column;
}

.icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon.ok {
  background: #52c41a;
}

.icon.fail {
  background: #cf1322;
}

.title {
  margin-top: 20rpx;
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.desc {
  margin-top: 12rpx;
  margin-bottom: 24rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.btn {
  margin-top: 12rpx;
  width: 320rpx;
  height: 68rpx;
  border-radius: 34rpx;
  font-size: 24rpx;
}

