.item {
  margin-top: 16rpx;
  padding: 16rpx;
  display: flex;
}

.cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.content {
  margin-left: 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.bottom {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.origin {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  text-decoration: line-through;
}

.btns {
  display: flex;
  gap: 12rpx;
}

.btn {
  height: 52rpx;
  min-width: 96rpx;
  padding: 0 14rpx;
  border-radius: 26rpx;
  font-size: 22rpx;
}

