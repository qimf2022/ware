<page-shell>
  <view class="container">
    <view class="card block">
      <view class="label">手机号</view>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onInputPhone" />

      <view class="label section-gap">验证码</view>
      <view class="code-row">
        <input class="input code-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onInputCode" />
        <view class="code-btn ui-btn ui-btn--secondary" bindtap="onSendCode">{{countdown > 0 ? (countdown + 's') : '发送验证码'}}</view>
      </view>
    </view>

    <view class="submit ui-btn ui-btn--primary" bindtap="onSubmit">确认绑定</view>
  </view>
</page-shell>
