.group {
  margin-top: 18rpx;
}

.date {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.record {
  padding: 14rpx;
  margin-bottom: 12rpx;
  display: flex;
}

.cover {
  width: 156rpx;
  height: 156rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.body {
  margin-left: 14rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.title {
  color: var(--text-primary);
  font-size: 25rpx;
}

.sub {
  margin-top: 6rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.row {
  margin-top: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add {
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 25rpx;
  border: 2rpx solid var(--brand-primary);
  color: var(--brand-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
