.search-bar {
  margin-top: 16rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
}

.input {
  flex: 1;
  height: 64rpx;
  border-radius: 32rpx;
  background: #f7f7f7;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.search-btn {
  margin-left: 10rpx;
  width: 120rpx;
  height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}


.panel {
  padding: 18rpx;
}

.panel-title {
  font-size: 25rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear {
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 400;
}

.chips {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  height: 52rpx;
  border-radius: 26rpx;
  border: 2rpx solid var(--border-color);
  padding: 0 18rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
}

.result-item {
  margin-top: 16rpx;
  padding: 14rpx;
  display: flex;
}

.cover {
  width: 168rpx;
  height: 168rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.info {
  margin-left: 14rpx;
  flex: 1;
}

.title {
  font-size: 26rpx;
  color: var(--text-primary);
}

.sub,
.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.origin {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  text-decoration: line-through;
}
