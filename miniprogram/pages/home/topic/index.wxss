.hero {
  margin-top: 20rpx;
  padding: 28rpx;
  background: linear-gradient(130deg, #6B2D5C 0%, #D81E06 100%);
}

.title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.btn {
  margin-top: 20rpx;
  width: 180rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}


.panel {
  padding: 20rpx;
}

.panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.activity {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border-color);
}

.activity:first-of-type {
  border-top: 0;
  padding-top: 8rpx;
}

.name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.text {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
}

.hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--brand-primary);
}

.link {
  margin-top: 20rpx;
  text-align: center;
  color: var(--brand-primary);
  font-size: 24rpx;
}
