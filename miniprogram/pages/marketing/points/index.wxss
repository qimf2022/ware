.balance {
  margin-top: 20rpx;
  padding: 24rpx;
  background: linear-gradient(145deg, #6B2D5C 0%, #9B4E81 100%);
}

.label {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

.num {
  margin-top: 8rpx;
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
}

.rule {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.6;
}

.records {
  padding: 20rpx;
}

.title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.item {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
}

.name {
  font-size: 24rpx;
  color: var(--text-primary);
}

.time {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}

.amount {
  font-size: 26rpx;
  font-weight: 600;
}

.plus {
  color: #1f9d55;
}

.minus {
  color: var(--brand-primary);
}
