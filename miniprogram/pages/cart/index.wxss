.cart-page {
  /* page-shell 已有 120rpx + safe-area 的 padding-bottom */
  /* 需要额外空间：action-bar 96rpx + tabBar 98rpx - 已有 120rpx = 74rpx */
  /* 加上一些间距，总共需要额外约 80rpx */
  padding-bottom: 200rpx;
}

.tip-row {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip {
  color: var(--text-muted);
  font-size: 30rpx;
}

.edit {
  color: var(--text-primary);
  font-size: 30rpx;
}

.item {
  margin-bottom: 16rpx;
  padding: 0;
  overflow: hidden;
}

/* 滑动删除容器 */
.swipe-item {
  height: 276rpx;
  overflow: hidden;
}

.movable-area {
  width: 100%;
  height: 276rpx;
}

.movable-view {
  width: calc(100% + 80px);
  height: 276rpx;
  display: flex;
  align-items: stretch;
}

.item-content {
  width: calc(100% - 80px);
  height: 100%;
  flex-shrink: 0;
  background: #fff;
}

.delete-btn {
  width: 80px;
  height: 100%;
  flex-shrink: 0;
  background: #ff4d4f;
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shop-row {
  height: 74rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f5f5f5;
}

.check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.check.checked {
  background: #ff4d4f;
  border-color: #ff4d4f;
  color: #fff;
}

.shop-name {
  margin-left: 16rpx;
  font-size: 30rpx;
  color: #666;
}

.item-main {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.cover {
  width: 156rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.content {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.name {
  font-size: 36rpx;
  color: #222;
  font-weight: 500;
  line-height: 1.35;
}

.spec {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #9a9a9a;
}

.price-row {
  margin-top: 18rpx;
}

.price {
  color: #ff3b30;
  font-size: 46rpx;
  font-weight: 600;
}

.origin {
  margin-left: 8rpx;
  font-size: 30rpx;
  color: #bbb;
  text-decoration: line-through;
}

.qty-box {
  margin-left: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.qty-btn.dec {
  background: #f5f5f5;
  color: #d8d8d8;
}

.qty-btn.dec.disabled {
  opacity: 0.55;
}

.qty-btn.inc {
  background: #ff4d4f;
  color: #fff;
}

.qty {
  width: 36rpx;
  text-align: center;
  color: #555;
  font-size: 30rpx;
}

.recommend-head {
  margin: 24rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.line {
  width: 64rpx;
  height: 2rpx;
  background: #ddd;
}

.text {
  font-size: 30rpx;
  color: #999;
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.recommend-item {
  overflow: hidden;
}

.recommend-cover {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
}

.recommend-content {
  padding: 14rpx;
}

.recommend-title {
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
  line-height: 1.4;
}

.recommend-sold {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #9a9a9a;
}

.recommend-bottom {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.recommend-price {
  color: #ff3b30;
  font-size: 46rpx;
  font-weight: 600;
}

.recommend-origin {
  margin-left: 8rpx;
  font-size: 30rpx;
  color: #bbb;
  text-decoration: line-through;
}

.add-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  border: 2rpx solid #ff4d4f;
  color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(98rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  height: 96rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #fff;
  padding: 0 20rpx;
  box-shadow: 0 -8rpx 16rpx rgba(0, 0, 0, 0.04);
}

.all {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #666;
  font-size: 32rpx;
}

.summary {
  flex: 1;
  color: #444;
  font-size: 34rpx;
}

.total {
  color: #ff3b30;
  font-weight: 600;
}

.checkout-btn {
  width: 238rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ff4d4f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
}

.checkout-btn.disabled {
  opacity: 0.45;
}

.empty-wrap {
  margin-top: 24rpx;
  padding: 96rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.icon {
  font-size: 72rpx;
}

.title {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.desc {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.go-btn {
  height: 64rpx;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

/* SKU弹窗样式 */
.sku-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}

.sku-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(98rpx + env(safe-area-inset-bottom));
  background: #fff;
  z-index: 1001;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.sku-head {
  display: flex;
  align-items: center;
}

.sku-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.sku-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.sku-price {
  color: #ff4d4f;
  font-size: 44rpx;
  font-weight: 600;
}

.sku-stock {
  margin-top: 8rpx;
  color: #9a9a9a;
  font-size: 24rpx;
}

.sku-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #999;
  font-size: 44rpx;
  line-height: 56rpx;
  text-align: center;
}

.sku-section {
  margin-top: 24rpx;
  border-top: 2rpx solid #f3f3f3;
  padding-top: 22rpx;
}

.sku-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sku-chips {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sku-chip {
  min-width: 112rpx;
  height: 60rpx;
  border-radius: 10rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background: #fff;
}

.sku-chip.active {
  border-color: #ff4d4f;
  color: #ff4d4f;
  background: #fff6f6;
}

.sku-chip.disabled {
  border-color: #ececec;
  color: #c3c3c3;
  background: #f7f7f7;
}

.sku-qty-row {
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #f3f3f3;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sku-qty-box {
  display: flex;
  align-items: center;
}

.sku-qty-btn {
  width: 72rpx;
  height: 56rpx;
  background: #f5f5f5;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.sku-qty-btn.disabled {
  background: #f0f0f0;
  color: #ccc;
}

.sku-qty-value {
  width: 86rpx;
  height: 56rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #333;
  border-top: 2rpx solid #f5f5f5;
  border-bottom: 2rpx solid #f5f5f5;
}

.sku-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.sku-add,
.sku-buy {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}

.sku-add {
  background: linear-gradient(90deg, #f4c55c 0%, #f0a93f 100%);
}

.sku-buy {
  background: linear-gradient(90deg, #ff8f8f 0%, #ff4d4f 100%);
}

.sku-add.disabled,
.sku-buy.disabled {
  opacity: 0.55;
}
