.detail-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.gallery {
  width: 100%;
  height: 720rpx;
}

.gallery-img {
  width: 100%;
  height: 100%;
}

.price-box {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.origin {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  text-decoration: line-through;
}

.section {
  padding: 24rpx;
}

.title {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.subtitle {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.sold {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.select-row {
  display: flex;
  align-items: center;
}

.select-label {
  width: 96rpx;
  font-size: 26rpx;
  color: #999;
}

.select-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.select-arrow {
  font-size: 36rpx;
  color: #aaa;
  line-height: 1;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 28rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.chip.active {
  color: var(--brand-primary);
  border-color: var(--brand-primary);
  background: #fff7f6;
}

.desc {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.assistant-text {
  margin-top: 14rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.recommend-title {
  margin-bottom: 12rpx;
}

.recommend-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  padding: 12rpx 16rpx calc(env(safe-area-inset-bottom) + 12rpx);
  box-shadow: 0 -8rpx 16rpx rgba(0, 0, 0, 0.04);
}

.mini-action {
  width: 78rpx;
  height: 78rpx;
  border-radius: 39rpx;
  border: 2rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 22rpx;
  background: #fff;
}

.mini-action.active {
  color: #ff4d4f;
  border-color: #ffc6c7;
  background: #fff5f5;
}


.ghost-btn,
.primary-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 39rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.ghost-btn {
  background: linear-gradient(90deg, #f4c55c 0%, #f0a93f 100%);
}

.primary-btn {
  background: linear-gradient(90deg, #ff8f8f 0%, #ff4d4f 100%);
}

.sku-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 30;
}

.sku-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  z-index: 31;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.sku-head {
  display: flex;
  align-items: center;
}

.sku-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
}

.sku-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.sku-price {
  color: #ff4d4f;
  font-size: 44rpx;
  font-weight: 600;
}

.sku-stock {
  margin-top: 8rpx;
  color: #9a9a9a;
  font-size: 24rpx;
}

.sku-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #999;
  font-size: 44rpx;
  line-height: 56rpx;
  text-align: center;
}

.sku-section {
  margin-top: 24rpx;
  border-top: 2rpx solid #f3f3f3;
  padding-top: 22rpx;
}

.sku-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sku-chips {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sku-chip {
  min-width: 112rpx;
  height: 60rpx;
  border-radius: 10rpx;
  padding: 0 22rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background: #fff;
}

.sku-chip.active {
  border-color: #ff4d4f;
  color: #ff4d4f;
  background: #fff6f6;
}

.sku-chip.disabled {
  border-color: #ececec;
  color: #c3c3c3;
  background: #f7f7f7;
}

.sku-qty-row {
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #f3f3f3;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sku-qty-box {
  display: flex;
  align-items: center;
}

.sku-qty-btn {
  width: 72rpx;
  height: 56rpx;
  background: #f5f5f5;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.sku-qty-btn.disabled {
  background: #f0f0f0;
  color: #ccc;
}

.sku-qty-value {
  width: 86rpx;
  height: 56rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #333;
  border-top: 2rpx solid #f5f5f5;
  border-bottom: 2rpx solid #f5f5f5;
}

.sku-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.sku-add,
.sku-buy {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}

.sku-add {
  background: linear-gradient(90deg, #f4c55c 0%, #f0a93f 100%);
}

.sku-buy {
  background: linear-gradient(90deg, #ff8f8f 0%, #ff4d4f 100%);
}

.sku-add.disabled,
.sku-buy.disabled {
  opacity: 0.55;
}


