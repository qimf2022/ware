.auth-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-modal-container {
  width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.auth-modal-header {
  padding: 48rpx 40rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.auth-modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.auth-modal-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.auth-modal-body {
  padding: 40rpx;
}

.auth-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.auth-avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  line-height: normal;
}

.auth-avatar-btn::after {
  border: none;
}

.auth-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #e8e8e8;
  background-color: #f5f5f5;
}

.auth-avatar-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.auth-nickname-section {
  position: relative;
}

.auth-nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.auth-nickname-input::placeholder {
  color: #bbb;
}

.auth-nickname-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.auth-modal-footer {
  display: flex;
  padding: 0 40rpx 40rpx;
  gap: 24rpx;
}

.auth-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.auth-btn::after {
  border: none;
}

.auth-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.auth-btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.auth-btn-confirm[disabled] {
  opacity: 0.6;
}
