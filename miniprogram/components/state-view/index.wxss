.state-wrap {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 72rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.error {
  color: #cf1322;
}

.btn {
  margin-top: 20rpx;
  min-width: 160rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--brand-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
