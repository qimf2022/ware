<view class="product-card card {{layout === 'row' ? 'row' : 'grid'}}" bindtap="onTapCard">
  <image class="cover" src="{{product.image}}" mode="aspectFill" lazy-load="true" />
  <view class="content">
    <view class="title">{{product.title}}</view>
    <view class="subtitle">{{product.subtitle}}</view>
    <view class="bottom">
      <view>
        <text class="price">¥{{product.price}}</text>
        <text class="origin">¥{{product.originPrice}}</text>
      </view>
      <view class="cart-btn" catchtap="onAddCart">🛒</view>
    </view>
  </view>
</view>
