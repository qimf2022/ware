.tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: #fff;
  border-top: 1rpx solid #efefef;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar {
  height: 98rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tabbar-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tabbar-icon {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 600;
}

.tabbar-icon.active {
  transform: scale(1.05);
}

.tabbar-text {
  font-size: 22rpx;
  line-height: 1;
}
